{
  "builds": [
    {
      "src": "pass_inventory/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "includeFiles": ["staticfiles/**", "inventory/templates/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "pass_inventory/wsgi.py"
    }
  ]
}
